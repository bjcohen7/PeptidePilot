# Runtime
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000

# Database
# MySQL-compatible URL used by Drizzle and the server.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Admin access
# Comma-separated emails that should be promoted to admin on login.
ADMIN_EMAILS=you@example.com,partner@example.com

# Manus/OAuth compatibility
VITE_APP_ID=
OAUTH_SERVER_URL=
JWT_SECRET=replace-with-a-long-random-string
OWNER_OPEN_ID=

# Optional Manus/Forge notification compatibility
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Optional integrations
VITE_META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=
WEBHOOK_TIER1_URL=
WEBHOOK_TIER2_URL=
WEBHOOK_TIER3_URL=

# Facebook Conversions API (CAPI) — server-side affiliate click tracking
# FB_PIXEL_ID takes precedence over VITE_META_PIXEL_ID when set.
# FB_CAPI_ACCESS_TOKEN takes precedence over META_CAPI_TOKEN when set.
# Remove FB_TEST_EVENT_CODE (or leave blank) in production to send real events.
FB_PIXEL_ID=
FB_CAPI_ACCESS_TOKEN=
FB_TEST_EVENT_CODE=

# Telegram notifications (affiliate click alerts to group chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
